class Netwhy < Formula
  desc "Explain why a network connection succeeds or fails"
  homepage "https://github.com/mqasimca/netwhy"
  url "https://github.com/mqasimca/netwhy/releases/download/v@VERSION@/netwhy-v@VERSION@-aarch64-apple-darwin.tar.gz"
  sha256 "@SHA256@"
  version "@VERSION@"
  license "MIT"

  depends_on arch: :arm64
  depends_on :macos

  def install
    bin.install "netwhy"
  end

  test do
    assert_match version.to_s, shell_output("#{bin}/netwhy --version")
  end
end
